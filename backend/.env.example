# Groq API Key — get free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT — change this to a long random string in production
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# App
APP_NAME=FoodChow RBAC Chatbot
APP_VERSION=1.0.0
DEBUG=True

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=foodchow_docs

# RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=llama-3.3-70b-versatile
TOP_K_RESULTS=5
CHUNK_SIZE=800
CHUNK_OVERLAP=150