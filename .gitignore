cat > .gitignore << 'EOF'
# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Environment variables — NEVER commit these
.env
.env.local
.env.production

# Vector DB — too large, regenerated by running ingest.py
backend/chroma_db/

# Logs
backend/logs/

# Next.js
frontend/.next/
frontend/node_modules/
frontend/out/

# Mac
.DS_Store

# VS Code
.vscode/settings.json
EOF